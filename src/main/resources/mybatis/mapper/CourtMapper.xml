<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tennis.dao.CourtMapper">

    <select id="findById" parameterType="int" resultType="com.tennis.entity.Court">
        SELECT * FROM courts WHERE id = #{id}
    </select>

    <select id="findAll" resultType="com.tennis.entity.Court">
        SELECT * FROM courts
    </select>

    <select id="findAvailable" resultType="com.tennis.entity.Court">
        SELECT * FROM courts WHERE status = 1
    </select>

    <insert id="insert" parameterType="com.tennis.entity.Court" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO courts (court_name, location, description, status, price, image_url, create_time)
        VALUES (#{courtName}, #{location}, #{description}, #{status}, #{price}, #{imageUrl}, #{createTime})
    </insert>

    <update id="update" parameterType="com.tennis.entity.Court">
        UPDATE courts
        SET court_name = #{courtName},
            location = #{location},
            description = #{description},
            status = #{status},
            price = #{price},
            image_url = #{imageUrl}
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="int">
        DELETE FROM courts WHERE id = #{id}
    </delete>

</mapper>
